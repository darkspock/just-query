{
    "name": "covermanager/fast-php-query-builder",
    "description": "Fast, lightweight PHP Query Builder with MySQL and PostgreSQL support, JSON schema provider, query profiler, and index hints. Forked from yiisoft/db.",
    "license": "BSD-3-Clause",
    "type": "library",
    "keywords": [
        "database",
        "query-builder",
        "mysql",
        "postgresql",
        "pdo",
        "sql",
        "force-index",
        "profiler",
        "schema"
    ],
    "homepage": "https://github.com/darkspock/FastPHPQueryBuilder",
    "support": {
        "issues": "https://github.com/darkspock/FastPHPQueryBuilder/issues",
        "source": "https://github.com/darkspock/FastPHPQueryBuilder"
    },
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "psr/log": "^2.0|^3.0",
        "psr/simple-cache": "^2.0|^3.0"
    },
    "suggest": {
        "ext-pdo_mysql": "Required for MySQL driver support",
        "ext-pdo_pgsql": "Required for PostgreSQL driver support"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "FastPHP\\QueryBuilder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FastPHP\\QueryBuilder\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
